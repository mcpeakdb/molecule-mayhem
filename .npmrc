# Supply-chain hardening: only install package versions that have been public for at
# least 3 days. Freshly-published malicious releases are usually detected and unpublished
# within hours, so this window dodges most of them. Requires npm >= 11.10 (the `engines`
# field below + engine-strict enforce that).
min-release-age=3

# Error (don't just warn) if the active Node/npm fall outside package.json "engines".
engine-strict=true
